# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development                          # development | production | test | staging
PORT=3000
LOG_LEVEL=info                                # fatal | error | warn | info | debug | trace | silent

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# Generate password: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=dev_password
DATABASE_URL=postgresql://app_user:dev_password@localhost:5432/platform_db
DATABASE_REPLICA_URL=postgresql://app_user:dev_password@localhost:5432/platform_db
TEST_DATABASE_URL=postgresql://app_user:dev_password@localhost:5432/platform_db_test

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# Generate password: openssl rand -hex 32
# For Redis Sentinel (HA) set REDIS_SENTINEL_HOSTS instead of REDIS_URL
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:dev_password@localhost:6379
REDIS_PASSWORD=dev_password
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# ─────────────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# Generate RSA-4096 key pair:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w 0 private.pem   →  JWT_PRIVATE_KEY_BASE64
#   base64 -w 0 public.pem    →  JWT_PUBLIC_KEY_BASE64
#   rm private.pem public.pem
# ─────────────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_BASE64=<base64-encoded-rsa-4096-private-key>
JWT_PUBLIC_KEY_BASE64=<base64-encoded-rsa-4096-public-key>
JWT_ACCESS_TOKEN_TTL=900                      # seconds — 900 = 15 min

# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTION & SECRETS
# ENCRYPTION_KEY — exactly 64 hex chars (32 bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# INVITE_SECRET — minimum 32 chars:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# METRICS_TOKEN — minimum 16 chars:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=<64-hex-chars>
INVITE_SECRET=<min-32-chars>
METRICS_TOKEN=<min-16-chars>

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# Production: set to your actual frontend domain(s), comma-separated
# Never use * in production
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# OBJECT STORAGE
# STORAGE_PROVIDER: local (dev only) | s3 (production + MinIO)
# MinIO (local dev via docker compose):
#   AWS_S3_ENDPOINT=http://localhost:9000
#   AWS_ACCESS_KEY_ID=minioadmin
#   AWS_SECRET_ACCESS_KEY=minioadmin
# AWS S3 (production): leave AWS_S3_ENDPOINT empty
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
AWS_REGION=ap-south-1
AWS_S3_BUCKET=dev-files
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=                              # http://localhost:9000 for MinIO; empty for real AWS S3

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Razorpay)
# Dashboard: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* keys for dev, rzp_live_* for production
# ─────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>
RAZORPAY_LIVE_TESTS=false

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL
# EMAIL_PROVIDER: smtp | ses | sendgrid
#
# Dev (Mailpit via docker compose up — catches all outgoing email):
#   EMAIL_PROVIDER=smtp, SMTP_HOST=localhost, SMTP_PORT=1025
#   UI at http://localhost:8025
#
# Production (AWS SES):
#   EMAIL_PROVIDER=ses — fill AWS_SES_* vars
#
# Production (SendGrid):
#   EMAIL_PROVIDER=sendgrid — fill SENDGRID_API_KEY
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp

AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

SENDGRID_API_KEY=SG.<your-sendgrid-api-key>

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=dev@localhost

# ─────────────────────────────────────────────────────────────────────────────
# SEARCH
# SEARCH_PROVIDER: postgres (built-in, no extra service) | typesense (full-text)
# Typesense runs via docker compose up
# ─────────────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=postgres
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=<your-typesense-api-key>

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM ADMIN
# IP_ALLOWLIST: CIDR ranges that can reach /api/v1/admin/*
# TRUSTED_PROXY: loopback | cloudflare | nginx (Express trust proxy docs)
# ─────────────────────────────────────────────────────────────────────────────
PLATFORM_ADMIN_IP_ALLOWLIST=127.0.0.1/32,::1/128
PLATFORM_ADMIN_TRUSTED_PROXY=loopback

# ─────────────────────────────────────────────────────────────────────────────
# VIRUS SCANNING (ClamAV)
# Runs via docker compose up — first boot downloads definitions (~300 MB, 2-5 min)
# Set VIRUS_SCAN_ENABLED=true in production
# ─────────────────────────────────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
VIRUS_SCAN_ENABLED=false                      # set true in production

# ─────────────────────────────────────────────────────────────────────────────
# VIDEO / WebRTC (LiveKit)
# Runs via docker compose up in --dev mode (key=devkey, secret=secret)
# Production: use LiveKit Cloud or self-hosted with real keys
# ─────────────────────────────────────────────────────────────────────────────
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (OpenTelemetry)
# Leave empty to disable tracing (fine for development)
# Production: point to your collector (Jaeger, Grafana Tempo, Honeycomb, etc.)
# ─────────────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=                  # e.g. http://localhost:4318/v1/traces

# ─────────────────────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────────────────────
OUTBOX_POLL_BATCH_SIZE=100
LOADTEST_ORG_ID=
LOADTEST_USER_PREFIX=loadtest_user_
