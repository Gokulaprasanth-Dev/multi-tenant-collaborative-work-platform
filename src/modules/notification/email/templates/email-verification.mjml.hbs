<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="20px" font-weight="bold">Verify your email address</mj-text>
        <mj-text>Hi {{name}},</mj-text>
        <mj-text>Please verify your email address by clicking the button below. This link expires in 24 hours.</mj-text>
        <mj-button href="{{verifyUrl}}" background-color="#4F46E5">Verify Email</mj-button>
        <mj-text font-size="12px" color="#6B7280">If you didn't create an account, you can safely ignore this email.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
