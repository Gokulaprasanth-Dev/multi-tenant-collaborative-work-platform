<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="20px" font-weight="bold">You were mentioned</mj-text>
        <mj-text>Hi {{recipientName}},</mj-text>
        <mj-text>{{actorName}} mentioned you in a comment on task <strong>{{taskTitle}}</strong>:</mj-text>
        <mj-text font-style="italic" color="#374151">"{{commentSnippet}}"</mj-text>
        <mj-button href="{{taskUrl}}" background-color="#4F46E5">View Comment</mj-button>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
