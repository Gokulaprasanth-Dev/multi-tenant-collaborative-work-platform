<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="20px" font-weight="bold">Reset your password</mj-text>
        <mj-text>Hi {{name}},</mj-text>
        <mj-text>We received a request to reset your password. Click the button below to set a new password. This link expires in 1 hour.</mj-text>
        <mj-button href="{{resetUrl}}" background-color="#4F46E5">Reset Password</mj-button>
        <mj-text font-size="12px" color="#6B7280">If you didn't request a password reset, you can safely ignore this email.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
