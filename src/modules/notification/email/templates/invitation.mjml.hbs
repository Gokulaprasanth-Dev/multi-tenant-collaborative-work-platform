<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text font-size="20px" font-weight="bold">You've been invited to {{orgName}}</mj-text>
        <mj-text>Hi there,</mj-text>
        <mj-text>{{inviterName}} has invited you to join <strong>{{orgName}}</strong> as a <strong>{{role}}</strong>.</mj-text>
        <mj-text>This invitation expires in 7 days.</mj-text>
        <mj-button href="{{acceptUrl}}" background-color="#4F46E5">Accept Invitation</mj-button>
        <mj-text font-size="12px" color="#6B7280">If you weren't expecting this invitation, you can safely ignore this email.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
