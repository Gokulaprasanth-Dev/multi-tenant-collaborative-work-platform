# Test environment — copy to .env.test and fill in values
# Used by: npm test
# All services must be running locally (docker compose up)

POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/platform_db
DATABASE_REPLICA_URL=postgresql://app_user:change_me@localhost:5432/platform_db
TEST_DATABASE_URL=postgresql://app_user:change_me@localhost:5432/platform_db_test

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Generate with: openssl genrsa -out private.pem 4096 && ...
JWT_PRIVATE_KEY_BASE64=<base64-encoded-rsa-4096-private-key>
JWT_PUBLIC_KEY_BASE64=<base64-encoded-rsa-4096-public-key>
JWT_ACCESS_TOKEN_TTL=900

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>
INVITE_SECRET=<min-32-chars>
METRICS_TOKEN=<min-16-chars>

PORT=3000
NODE_ENV=test
LOG_LEVEL=silent
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

STORAGE_PROVIDER=s3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=dev-files
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT=http://localhost:9000

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your-razorpay-test-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>
RAZORPAY_LIVE_TESTS=false

EMAIL_PROVIDER=smtp
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@example.com
SENDGRID_API_KEY=SG.placeholder
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=dev@localhost

SEARCH_PROVIDER=typesense
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=<your-typesense-api-key>

PLATFORM_ADMIN_IP_ALLOWLIST=127.0.0.1/32,::1/128
PLATFORM_ADMIN_TRUSTED_PROXY=loopback

CLAMAV_HOST=localhost
CLAMAV_PORT=3310
VIRUS_SCAN_ENABLED=true

LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

OTEL_EXPORTER_OTLP_ENDPOINT=
OUTBOX_POLL_BATCH_SIZE=100
LOADTEST_ORG_ID=
LOADTEST_USER_PREFIX=loadtest_user_
