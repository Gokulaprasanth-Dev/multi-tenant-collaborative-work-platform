{
  "name": "multi-tenant-collaborative-work-platform",
  "version": "1.0.0",
  "description": "Production-ready multi-tenant SaaS platform with real-time collaboration, task management, chat, file storage, search, webhooks, payments, and GDPR compliance",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "start:worker": "node dist/worker.js",
    "dev": "ts-node --transpile-only src/app.ts",
    "dev:worker": "ts-node --transpile-only src/worker.ts",
    "migrate:up": "node-pg-migrate up --migration-file-language js",
    "migrate:down": "node-pg-migrate down --migration-file-language js",
    "migrate:test": "DATABASE_URL=$TEST_DATABASE_URL node-pg-migrate up --migration-file-language js",
    "test:unit": "jest --testPathPattern=tests/unit --passWithNoTests --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --passWithNoTests --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --passWithNoTests --forceExit",
    "test:smoke": "jest --testPathPattern=tests/smoke --runInBand --passWithNoTests --forceExit",
    "seed:loadtest": "ts-node scripts/seed-loadtest.ts",
    "generate:openapi": "ts-node scripts/generate-openapi.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["saas", "multi-tenant", "collaboration", "task-management", "real-time", "nodejs", "typescript", "postgresql", "redis", "socket.io"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gokulaprasanth-Dev/multi-tenant-collaborative-work-platform.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-ses": "^3.1019.0",
    "@aws-sdk/lib-storage": "^3.1019.0",
    "@aws-sdk/s3-presigned-post": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@opentelemetry/auto-instrumentations-node": "0.39.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.45.0",
    "@opentelemetry/sdk-node": "0.45.0",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "archiver": "^6.0.2",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "clamscan": "^2.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "file-type": "^16.5.4",
    "google-auth-library": "^9.15.1",
    "handlebars": "^4.7.9",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mjml": "^4.18.0",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^6.2.2",
    "nodemailer": "^8.0.4",
    "opossum": "^7.1.0",
    "otplib": "^12.0.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-saml": "^3.2.4",
    "pg": "^8.20.0",
    "pino": "^8.21.0",
    "pino-http": "^8.6.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "rrule": "^2.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typesense": "1.5.4",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/clamscan": "^2.4.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.19.37",
    "@types/opossum": "^8.1.9",
    "@types/passport": "^1.0.17",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
